// ===========================================
// SISTEMA DE APOIO PEDAGÓGICO
// Regras de Segurança - Firestore
// ===========================================
//
// Coleções:
//   print_jobs          - Solicitações de impressão
//   equipment_bookings  - Reservas de equipamentos
//   material_withdrawals - Retiradas de materiais
//
// O sistema usa senha fixa (12345) no cliente.
// Sem Firebase Auth configurado, o acesso é público.
// ===========================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Impressões ---
    match /print_jobs/{docId} {
      // Qualquer um pode ler (app precisa listar)
      allow read: if true;
      // Professores e sala de impressão podem criar
      allow create: if true;
      // Atualizar status (pending -> printed)
      allow update: if true;
      // Auto-cleanup remove após 7 dias
      allow delete: if true;
    }

    // --- Reservas de Equipamentos ---
    match /equipment_bookings/{docId} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      // Auto-cleanup remove reservas de datas passadas
      allow delete: if true;
    }

    // --- Retiradas de Materiais ---
    match /material_withdrawals/{docId} {
      allow read: if true;
      allow create: if true;
      // Permitir exclusão (botão ✕ no histórico)
      allow delete: if true;
      allow update: if false;
    }
  }
}


